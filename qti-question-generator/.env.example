# ==============================================
# QTI Question Generator - 環境設定
# ==============================================
# このファイルを .env にコピーして、値を設定してください
# cp .env.example .env

# Claude API キー（必須）
# 取得先: https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-api03-xxxxx

# 使用するモデル
# claude-sonnet-4-20250514 (推奨、バッチ処理で50%割引)
# claude-3-5-haiku-20241022 (低コスト)
# claude-opus-4-20250514 (最高品質)
DEFAULT_MODEL=claude-sonnet-4-20250514

# 品質スコア閾値（0-100）
# この値以上のスコアの問題のみ採用
QUALITY_THRESHOLD=80

# バッチサイズ（一度に生成する問題数）
BATCH_SIZE=10

# ==============================================
# Vercel Blob ストレージ
# ==============================================
# 取得先: https://vercel.com/dashboard → Storage → Blob → Tokens
BLOB_READ_WRITE_TOKEN=vercel_blob_rw_xxxxx

# ==============================================
# Phase 2以降で使用（現在は不要）
# ==============================================
# DATABASE_URL=postgresql://user:pass@ep-xxx.region.aws.neon.tech/neondb
