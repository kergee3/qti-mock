# ==============================================
# QTI Question Generator - 環境設定
# ==============================================
# このファイルを .env にコピーして、値を設定してください
# cp .env.example .env

# Claude API キー（必須）
# 取得先: https://console.anthropic.com/
ANTHROPIC_API_KEY=REDACTED_API_KEY



# 品質スコア閾値（0-100）
# この値以上のスコアの問題のみ採用
QUALITY_THRESHOLD=80

# バッチサイズ（一度に生成する問題数）
BATCH_SIZE=5


# ==============================================
# Vercel Blob ストレージ
# ==============================================
# 取得先: https://vercel.com/dashboard → Storage → Blob → Tokens
BLOB_READ_WRITE_TOKEN="REDACTED_BLOB_TOKEN"

# ==============================================
# Phase 2以降で使用（現在は不要）
# ==============================================
# DATABASE_URL=postgresql://user:pass@ep-xxx.region.aws.neon.tech/neondb
