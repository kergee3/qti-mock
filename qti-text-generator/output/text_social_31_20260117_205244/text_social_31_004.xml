<?xml version="1.0" encoding="UTF-8"?>
<qti-assessment-item xmlns="http://www.imsglobal.org/xsd/imsqti_v3p0" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" identifier="text-8220263100000000-004" title="政治への参加と責任" adaptive="false" time-dependent="false">
  <qti-response-declaration identifier="RESPONSE" base-type="string" cardinality="single"/>
  <qti-outcome-declaration identifier="SCORE" cardinality="single" base-type="float" external-scored="human">
    <qti-default-value>
      <qti-value>0</qti-value>
    </qti-default-value>
  </qti-outcome-declaration>
  <qti-rubric-block view="scorer" use="ai-scoring">
    <scoring-criteria>
      <model-answer>選挙では国民の代表となる人を選んで政治に参加し、納税では国や地方の政策に必要な費用を負担する。この2つを通して国民として責任を果たし、よりよい社会づくりに貢献したい。</model-answer>
      <required-concepts>
        <concept>国民主権</concept>
        <concept>選挙の意味</concept>
        <concept>租税の役割</concept>
        <concept>政治参加</concept>
        <concept>国民の権利と義務</concept>
      </required-concepts>
      <scoring-matrix>
        <criterion aspect="understanding" aspect-name="理解力" max-score="4">
          <level score="4">政治参加の方法とその意味を正確に理解している</level>
          <level score="3">政治参加の方法とその意味を概ね理解している</level>
          <level score="2">政治参加の方法を部分的に理解している</level>
          <level score="1">政治参加の方法の理解が不十分</level>
          <level score="0">政治参加の方法を理解していない</level>
        </criterion>
        <criterion aspect="expression" aspect-name="表現力" max-score="3">
          <level score="3">論理的で自分の考えを明確に表現している</level>
          <level score="2">概ね論理的で考えを表現している</level>
          <level score="1">考えの表現がやや不明確</level>
          <level score="0">考えが適切に表現されていない</level>
        </criterion>
        <criterion aspect="accuracy" aspect-name="正確性" max-score="3">
          <level score="3">政治用語を正確に使用している</level>
          <level score="2">政治用語を概ね正確に使用している</level>
          <level score="1">政治用語の使用が一部不正確</level>
          <level score="0">政治用語の使用が不正確</level>
        </criterion>
      </scoring-matrix>
      <common-errors>
        <error pattern="選挙や納税の意味を表面的にしか理解していない" feedback="選挙は国民の代表を選ぶ大切な権利、納税は社会を支える義務であることを理解しましょう。"/>
        <error pattern="自分の考えが含まれていない客観的な説明のみ" feedback="政治への関わり方について、あなた自身の考えや意見を含めて答えましょう。"/>
        <error pattern="2つ以上の政治参加の方法が挙げられていない" feedback="問題で指定された選挙、納税、法律を守ることの中から2つ以上を選んで答えましょう。"/>
      </common-errors>
      <char-limits min="60" max="100"/>
    </scoring-criteria>
  </qti-rubric-block>
  <qti-item-body>
    <div class="question-text">
      <p>あなたが大人になったとき、よりよい社会をつくるために政治にどのように関わりたいと思いますか。選挙、納税、法律を守ることの中から2つ以上を挙げて、それぞれの意味と自分の考えを述べなさい。（60～100文字）</p>
    </div>
    <qti-extended-text-interaction response-identifier="RESPONSE" expected-length="100" min-strings="1" max-strings="1" expected-lines="5" format="plain" class="qti-counter-up">
      <qti-prompt>
        <p>以下の条件に従って回答してください：</p>
        <ul>
          <li>60文字以上100文字以内で回答すること</li>
          <li>60文字未満の回答は採点対象外となります</li>
        </ul>
      </qti-prompt>
    </qti-extended-text-interaction>
  </qti-item-body>
</qti-assessment-item>
