<?xml version="1.0" encoding="UTF-8"?>
<qti-assessment-item xmlns="http://www.imsglobal.org/xsd/imsqti_v3p0" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" identifier="text-8220263100000000-002" title="政治の追究・解決活動の意義" adaptive="false" time-dependent="false">
  <qti-response-declaration identifier="RESPONSE" base-type="string" cardinality="single"/>
  <qti-outcome-declaration identifier="SCORE" cardinality="single" base-type="float" external-scored="human">
    <qti-default-value>
      <qti-value>0</qti-value>
    </qti-default-value>
  </qti-outcome-declaration>
  <qti-rubric-block view="scorer" use="ai-scoring">
    <scoring-criteria>
      <model-answer>市民は選挙で代表者を選び、意見を伝える。市議会は市民の声を聞いて予算や条例を決める。市役所は議会で決まったことに基づいて実際に公園づくりを進める。このように民主的に問題を解決する。</model-answer>
      <required-concepts>
        <concept>民主政治</concept>
        <concept>市民参加</concept>
        <concept>三権の役割</concept>
      </required-concepts>
      <scoring-matrix>
        <criterion aspect="understanding" aspect-name="理解力" max-score="4">
          <level score="4">完全に理解している</level>
          <level score="3">概ね理解している</level>
          <level score="2">部分的に理解している</level>
          <level score="1">理解が不十分</level>
          <level score="0">理解していない</level>
        </criterion>
        <criterion aspect="expression" aspect-name="表現力" max-score="3">
          <level score="3">論理的で明確な表現</level>
          <level score="2">概ね論理的な表現</level>
          <level score="1">やや不明確な表現</level>
          <level score="0">表現が不適切</level>
        </criterion>
        <criterion aspect="accuracy" aspect-name="正確性" max-score="3">
          <level score="3">正確で適切な用語使用</level>
          <level score="2">概ね正確</level>
          <level score="1">一部不正確</level>
          <level score="0">不正確</level>
        </criterion>
      </scoring-matrix>
      <common-errors>
        <error pattern="市民の役割のみを述べて議会や行政の役割に触れない" feedback="市民だけでなく、市議会や市役所の役割も含めて民主的な問題解決の過程を説明しましょう"/>
        <error pattern="具体的な例がなく抽象的な説明にとどまる" feedback="公園づくりの具体例を使って、どのような手順で問題が解決されるかを説明しましょう"/>
        <error pattern="政治の働きではなく一般的な問題解決方法を述べる" feedback="民主政治の仕組みを使った問題解決について、選挙や議会の役割を含めて説明しましょう"/>
      </common-errors>
      <char-limits min="60" max="100"/>
    </scoring-criteria>
  </qti-rubric-block>
  <qti-item-body>
    <div class="question-text">
      <p>あなたの住む市で「公園を増やしてほしい」という市民の声があるとします。この問題について、市民、市議会、市役所がそれぞれどのような役割を果たして解決していくのか、具体例を挙げながら60文字以上で説明しなさい。</p>
    </div>
    <qti-extended-text-interaction response-identifier="RESPONSE" expected-length="100" min-strings="1" max-strings="1" expected-lines="5" format="plain" class="qti-counter-up">
      <qti-prompt>
        <p>以下の条件に従って回答してください：</p>
        <ul>
          <li>60文字以上100文字以内で回答すること</li>
          <li>60文字未満の回答は採点対象外となります</li>
        </ul>
      </qti-prompt>
    </qti-extended-text-interaction>
  </qti-item-body>
</qti-assessment-item>
