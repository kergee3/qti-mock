<?xml version="1.0" encoding="UTF-8"?>
<qti-assessment-item
  xmlns="http://www.imsglobal.org/xsd/imsqtiasi_v3p0"
  identifier="order-item-001"
  title="並べ替え問題サンプル"
  adaptive="false"
  time-dependent="false">

  <qti-response-declaration identifier="RESPONSE" cardinality="ordered" base-type="identifier">
    <qti-correct-response>
      <qti-value>A</qti-value>
      <qti-value>B</qti-value>
      <qti-value>C</qti-value>
      <qti-value>D</qti-value>
    </qti-correct-response>
  </qti-response-declaration>

  <qti-outcome-declaration identifier="SCORE" cardinality="single" base-type="float">
    <qti-default-value>
      <qti-value>0</qti-value>
    </qti-default-value>
  </qti-outcome-declaration>

  <qti-item-body>
    <p>次の都道府県を北から南の順に並べ替えてください。</p>
    <qti-order-interaction response-identifier="RESPONSE" shuffle="true">
      <qti-simple-choice identifier="A">北海道</qti-simple-choice>
      <qti-simple-choice identifier="B">東京都</qti-simple-choice>
      <qti-simple-choice identifier="C">大阪府</qti-simple-choice>
      <qti-simple-choice identifier="D">沖縄県</qti-simple-choice>
    </qti-order-interaction>
  </qti-item-body>

  <qti-response-processing
    template="https://purl.imsglobal.org/spec/qti/v3p0/rptemplates/match_correct"/>
</qti-assessment-item>
