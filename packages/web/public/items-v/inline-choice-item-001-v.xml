<?xml version="1.0" encoding="UTF-8"?>
<qti-assessment-item
  xmlns="http://www.imsglobal.org/xsd/imsqtiasi_v3p0"
  identifier="inline-choice-item-001-v"
  title="富士山はどんな山ですか？（縦書き）"
  adaptive="false"
  time-dependent="false"
  xml:lang="ja">

  <qti-response-declaration identifier="RESPONSE" cardinality="single" base-type="identifier">
    <qti-correct-response>
      <qti-value>choice_a</qti-value>
    </qti-correct-response>
  </qti-response-declaration>

  <qti-outcome-declaration identifier="SCORE" cardinality="single" base-type="float">
    <qti-default-value>
      <qti-value>0</qti-value>
    </qti-default-value>
  </qti-outcome-declaration>

  <qti-item-body>
    <div class="qti-height-96 qti3-player-writing-mode-vertical-rl qti3-player-float-right">
      <p>次の文の空欄に入る最も適切な語を選んでください。</p>
      <p>
        富士山は日本で最も
        <qti-inline-choice-interaction response-identifier="RESPONSE" shuffle="false">
          <qti-inline-choice identifier="choice_a">高い</qti-inline-choice>
          <qti-inline-choice identifier="choice_b">広い</qti-inline-choice>
          <qti-inline-choice identifier="choice_c">長い</qti-inline-choice>
          <qti-inline-choice identifier="choice_d">深い</qti-inline-choice>
        </qti-inline-choice-interaction>
        山です。
      </p>
    </div>
  </qti-item-body>

  <qti-response-processing
    template="https://purl.imsglobal.org/spec/qti/v3p0/rptemplates/match_correct"/>
</qti-assessment-item>
