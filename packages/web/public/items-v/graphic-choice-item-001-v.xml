<?xml version="1.0" encoding="UTF-8"?>
<qti-assessment-item
  xmlns="http://www.imsglobal.org/xsd/imsqtiasi_v3p0"
  identifier="graphic-choice-item-001-v"
  title="東京はどこですか？（縦書き）"
  adaptive="false"
  time-dependent="false"
  xml:lang="ja">

  <qti-response-declaration identifier="RESPONSE" cardinality="single" base-type="identifier">
    <qti-correct-response>
      <qti-value>hotspot_tokyo</qti-value>
    </qti-correct-response>
  </qti-response-declaration>

  <qti-outcome-declaration identifier="SCORE" cardinality="single" base-type="float">
    <qti-default-value>
      <qti-value>0</qti-value>
    </qti-default-value>
  </qti-outcome-declaration>

  <qti-item-body>
    <!-- 縦書き判定用マーカー（非表示） -->
    <span class="qti3-player-writing-mode-vertical-rl" style="display: none;"></span>
    <div style="display: flex; flex-direction: row; align-items: flex-start; justify-content: flex-end; gap: 1.5rem;">
      <!-- 左側：地図画像 -->
      <qti-hotspot-interaction response-identifier="RESPONSE" max-choices="1">
        <object type="image/svg+xml" data="/items/images/japan-map.svg" width="400" height="300">日本地図</object>
        <qti-hotspot-choice identifier="hotspot_tokyo" shape="circle" coords="267,193,20" hotspot-label="東京"/>
        <qti-hotspot-choice identifier="hotspot_osaka" shape="circle" coords="172,218,20" hotspot-label="大阪"/>
        <qti-hotspot-choice identifier="hotspot_kyoto" shape="circle" coords="176,205,20" hotspot-label="京都"/>
        <qti-hotspot-choice identifier="hotspot_nagoya" shape="circle" coords="210,209,20" hotspot-label="名古屋"/>
      </qti-hotspot-interaction>
      <!-- 右側：縦書きテキスト2列 -->
      <div style="display: flex; flex-direction: row; gap: 1rem;">
        <p style="writing-mode: vertical-rl; margin: 0; line-height: 1.8;">下の地図から東京を選んでください。</p>
        <p style="writing-mode: vertical-rl; margin: 0; line-height: 1.8;">日本地図上で東京の位置をクリックしてください。</p>
      </div>
    </div>
  </qti-item-body>

  <qti-response-processing
    template="https://purl.imsglobal.org/spec/qti/v3p0/rptemplates/match_correct"/>
</qti-assessment-item>
