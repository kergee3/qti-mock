<?xml version="1.0" encoding="UTF-8"?>
<qti-assessment-item
  xmlns="http://www.imsglobal.org/xsd/imsqtiasi_v3p0"
  identifier="match-item-001-v"
  title="国と首都を合わせよう（縦書き）"
  adaptive="false"
  time-dependent="false"
  xml:lang="ja">

  <qti-response-declaration identifier="RESPONSE" cardinality="multiple" base-type="directedPair">
    <qti-correct-response>
      <qti-value>C1 M1</qti-value>
      <qti-value>C2 M2</qti-value>
      <qti-value>C3 M3</qti-value>
    </qti-correct-response>
  </qti-response-declaration>

  <qti-outcome-declaration identifier="SCORE" cardinality="single" base-type="float">
    <qti-default-value>
      <qti-value>0</qti-value>
    </qti-default-value>
  </qti-outcome-declaration>

  <qti-item-body>
    <div class="qti-height-96 qti3-player-writing-mode-vertical-rl qti3-player-float-right">
      <p>次の国と首都を正しく組み合わせてください。</p>
      <qti-match-interaction response-identifier="RESPONSE" shuffle="false" max-associations="3">
        <qti-simple-match-set>
          <qti-simple-associable-choice identifier="C1" match-max="1">日本</qti-simple-associable-choice>
          <qti-simple-associable-choice identifier="C2" match-max="1">フランス</qti-simple-associable-choice>
          <qti-simple-associable-choice identifier="C3" match-max="1">イギリス</qti-simple-associable-choice>
        </qti-simple-match-set>
        <qti-simple-match-set>
          <qti-simple-associable-choice identifier="M1" match-max="1">東京</qti-simple-associable-choice>
          <qti-simple-associable-choice identifier="M2" match-max="1">パリ</qti-simple-associable-choice>
          <qti-simple-associable-choice identifier="M3" match-max="1">ロンドン</qti-simple-associable-choice>
        </qti-simple-match-set>
      </qti-match-interaction>
    </div>
  </qti-item-body>

  <qti-response-processing
    template="https://purl.imsglobal.org/spec/qti/v3p0/rptemplates/match_correct"/>
</qti-assessment-item>
