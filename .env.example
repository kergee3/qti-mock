# ==============================================
# QTI Generators - 共通環境設定
# ==============================================
# このファイルをルートの .env にコピーして値を設定
# cp .env.example .env

# Claude API キー（必須）
# 取得先: https://console.anthropic.com/
ANTHROPIC_API_KEY=your-anthropic-api-key-here

# 使用するモデル
# claude-haiku-4-5-20251001 (低コスト)
# claude-sonnet-4-5-20250929 (推奨)
# claude-opus-4-5-20251101 (最高品質)
DEFAULT_MODEL=claude-sonnet-4-5-20250929

# Vercel Blob ストレージ
# 取得先: https://vercel.com/dashboard → Storage → Blob → Tokens
BLOB_READ_WRITE_TOKEN=your-vercel-blob-token-here
